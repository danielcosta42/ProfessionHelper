# Profession Helper - .gitignore

# WoW SavedVariables
*.bak
*.old
*.tmp

# Development
.vscode/
.idea/
*.swp
*.swo
*~

# OS Files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Package/Release
*.zip
releases/

# Developer Documentation (not needed in repo)
LOCALIZATION.md
PUBLISHING.md
SCREENSHOTS.md
MARKETING.md
PACKAGE-STATUS.md
CREATE-PACKAGE.md

# GitHub Actions setup docs (keep workflows, but hide detailed setup)
.github/CICD-SETUP.md
.github/RELEASE-GUIDE.md
.github/SEMVER-QUICKSTART.md
.github/SEMVER-VISUAL-GUIDE.md

# Test files
test/
temp/

# Luacheck cache
.luacheckcache
